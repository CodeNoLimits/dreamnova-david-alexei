# DreamNova Consult — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# Site
NEXT_PUBLIC_SITE_URL=https://dreamnova.co.il
NEXT_PUBLIC_SITE_NAME=DreamNova Consult

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=972XXXXXXXXX

# Email
NEXT_PUBLIC_CONTACT_EMAIL=dreamnovaultimate@gmail.com

# Supabase (Phase 2 — Leads CRM)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Phase 2 — Payments)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=

# Google Analytics
# NEXT_PUBLIC_GA_ID=

# Vercel
# VERCEL_TOKEN=
